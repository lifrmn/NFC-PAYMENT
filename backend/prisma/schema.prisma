generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  password  String
  balance   Float    @default(0)
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sentTransactions     Transaction[] @relation("SenderTransactions")
  receivedTransactions Transaction[] @relation("ReceiverTransactions")
  fraudAlerts          FraudAlert[]
  userSessions         UserSession[]
  // Policy: 1 user hanya boleh memiliki 1 kartu NFC aktif (enforced di application layer /register).
  // Relasi dideklarasikan one-to-many di schema Prisma, namun kode aplikasi membatasi
  // setiap user untuk satu kartu NFC aktif saja. Lihat endpoint POST /nfc-cards/register.
  nfcCards             NFCCard[]

  @@map("users")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  amount      Float
  type        String   @default("transfer")
  status      String   @default("completed") // completed, pending, failed
  description String?
  deviceId    String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sender   User @relation("SenderTransactions", fields: [senderId], references: [id])
  receiver User @relation("ReceiverTransactions", fields: [receiverId], references: [id])

  // Fraud Detection (Z-Score Based Anomaly Detection)
  fraudRiskScore Float?  // Menyimpan nilai Z-Score aktual
  fraudRiskLevel String? // NORMAL, SUSPICIOUS, ANOMALY (sesuai implementasi Z-Score)
  fraudReasons   String? // JSON array of reasons
  fraudAlerts    FraudAlert[] // FraudAlert untuk REVIEW dibuat SETELAH Transaction tersimpan

  @@map("transactions")
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model FraudAlert {
  id             Int      @id @default(autoincrement())
  userId         Int?
  transactionId  Int?     // ID transaksi terkait. Null jika BLOCK (tidak ada transaksi). Harus terisi untuk REVIEW.
  deviceId       String
  deviceName     String?
  riskScore      Float  // Nilai Z-Score aktual (float). Sentinel -1 = Z tidak terdefinisi (σ=0, X≠μ).
  riskLevel      String // NORMAL, SUSPICIOUS, ANOMALY (sesuai Z-Score: ≤2, 2<Z≤3, >3)
  decision       String // ALLOW, REVIEW, BLOCK (hanya REVIEW/BLOCK yang membuat FraudAlert)
  reasons        String // JSON array
  confidence     Float
  riskFactors    String // JSON object
  status         String   @default("NEW") // NEW, REVIEWED, RESOLVED
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user        User?        @relation(fields: [userId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@map("fraud_alerts")
}

model Device {
  id           Int      @id @default(autoincrement())
  deviceId     String   @unique
  deviceName   String
  platform     String   @default("android")
  appVersion   String?
  osVersion    String?
  ipAddress    String?
  isOnline     Boolean  @default(false)
  lastSeen     DateTime @default(now())
  totalUsers   Int      @default(0)
  totalBalance Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("devices")
}

model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  deviceId  String
  token     String   @unique
  expiresAt DateTime
  isActive  Boolean  @default(true)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  action    String // LOGIN, BALANCE_UPDATE, USER_CREATE, etc
  details   String? // JSON details
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("admin_logs")
}

model SystemSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json

  @@map("system_settings")
}

model NFCCard {
  id           Int      @id @default(autoincrement())
  cardId       String   @unique // UID dari NTag215
  cardType     String   @default("NTag215") // NTag215, Mifare, etc
  frequency    String   @default("13.56MHz")
  userId       Int?     // Link ke user (null jika belum teregistrasi)
  cardStatus   String   @default("ACTIVE") // ACTIVE, BLOCKED, LOST, EXPIRED
  balance      Float    @default(0)
  lastUsed     DateTime?
  registeredAt DateTime @default(now())
  expiresAt    DateTime?
  isPhysical   Boolean  @default(true) // Physical card vs virtual
  cardData     String? // Encrypted data dari chip
  metadata     String? // JSON: manufacturer, batch, etc
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User?    @relation(fields: [userId], references: [id])
  transactions NFCTransaction[]

  @@map("nfc_cards")
  @@index([cardId])
  @@index([userId])
  @@index([cardStatus])
}

model NFCTransaction {
  id              Int      @id @default(autoincrement())
  cardId          String
  transactionType String   // TAP_IN, TAP_OUT, PAYMENT, TOP_UP
  amount          Float?
  balanceBefore   Float
  balanceAfter    Float
  deviceId        String
  location        String?
  ipAddress       String?
  status          String   @default("SUCCESS") // SUCCESS, FAILED, PENDING
  errorMessage    String?
  fraudScore      Float?
  metadata        String? // JSON: signal strength, read time, etc
  createdAt       DateTime @default(now())

  // Relations
  card            NFCCard  @relation(fields: [cardId], references: [cardId])

  @@map("nfc_transactions")
  @@index([cardId])
  @@index([createdAt])
}
